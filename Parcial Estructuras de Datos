            print(f"     Tipo        : {eliminado['tipo']}")
            print(f"     Aparición   : {eliminado['anio']}")
            print(f"     Biografía   : {eliminado['bio']}")
            break
    else:
        print(f"\n  ❌ '{nombre_del}' NO estaba en la lista.")

print(f"\n  Total de personajes tras eliminación: {len(personajes_marvel)}")
