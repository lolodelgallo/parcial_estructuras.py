ordenados_nombre = sorted(personajes_marvel, key=lambda p: p["nombre"])
for p in ordenados_nombre:
    print(f"  {p['nombre']}")

# ── 2. Posición de The Thing y Rocket Raccoon ───────────────
separador("EJ.2.2 - POSICIÓN DE THE THING Y ROCKET RACCOON")

nombres_buscar = ["The Thing", "Rocket Raccoon"]
for nombre_buscar in nombres_buscar:
    for i, p in enumerate(ordenados_nombre):
        if p["nombre"] == nombre_buscar:
            print(f"  '{nombre_buscar}' está en la posición {i + 1} (índice {i}) de la lista ordenada.")
            break

# ── 3. Listar todos los villanos ────────────────────────────
separador("EJ.2.3 - VILLANOS DE LA LISTA")

villanos = [p for p in personajes_marvel if p["tipo"] == "villano"]
for v in villanos:
    print(f"  🦹 {v['nombre']} ({v['nombre_real']}) - {v['anio']}")

# ── 4. Cola de villanos → filtrar anteriores a 1980 ─────────
separador("EJ.2.4 - COLA DE VILLANOS: APARECIERON ANTES DE 1980")

cola_villanos = deque()
for v in villanos:
    cola_villanos.append(v)

print(f"  Total en cola: {len(cola_villanos)} villanos\n")
print("  Villanos que aparecieron ANTES de 1980:")
villanos_antes_1980 = []
while cola_villanos:
    villano = cola_villanos.popleft()
    if villano["anio"] < 1980:
        villanos_antes_1980.append(villano)
        print(f"    ⚡ {villano['nombre']} - {villano['anio']}")

print(f"\n  Total antes de 1980: {len(villanos_antes_1980)}")

# ── 5. Héroes que comienzan con Bl, G, My, W ────────────────
separador("EJ.2.5 - HÉROES QUE COMIENZAN CON Bl, G, My, W")

prefijos = ["Bl", "G", "My", "W"]
for pref in prefijos:
    coincidencias = [p for p in personajes_marvel
                     if p["nombre"].startswith(pref) and p["tipo"] == "heroe"]
    print(f"\n  Prefijo '{pref}':")
    if coincidencias:
        for c in coincidencias:
            print(f"    → {c['nombre']}")
    else:
        print(f"    (ninguno)")

# ── 6. Ordenado por nombre real ascendente ──────────────────
separador("EJ.2.6 - ORDENADO POR NOMBRE REAL (ASCENDENTE)")

ordenados_real = sorted(personajes_marvel, key=lambda p: p["nombre_real"])
for p in ordenados_real:
    print(f"  {p['nombre_real']:<30} → {p['nombre']}")

# ── 7. Héroes ordenados por fecha de aparición ──────────────
separador("EJ.2.7 - HÉROES ORDENADOS POR FECHA DE APARICIÓN")

heroes_por_fecha = sorted(
    [p for p in personajes_marvel if p["tipo"] == "heroe"],
    key=lambda p: p["anio"]
)
for p in heroes_por_fecha:
    print(f"  {p['anio']} - {p['nombre']}")

# ── 8. Modificar nombre real de Ant-Man → Scott Lang ────────
separador("EJ.2.8 - MODIFICAR NOMBRE REAL DE ANT-MAN")

for p in personajes_marvel:
    if p["nombre"] == "Ant-Man":
        print(f"  Antes: {p['nombre']} → {p['nombre_real']}")
        p["nombre_real"] = "Scott Lang"
        print(f"  Después: {p['nombre']} → {p['nombre_real']}")
        break

# ── 9. Personajes cuya bio incluye "time-traveling" o "suit" ─
separador("EJ.2.9 - BIO INCLUYE 'time-traveling' O 'suit'")

palabras_clave = ["time-traveling", "suit"]
for p in personajes_marvel:
    bio_lower = p["bio"].lower()
    encontradas = [pal for pal in palabras_clave if pal in bio_lower]
    if encontradas:
        print(f"  [{', '.join(encontradas)}] {p['nombre']}: {p['bio']}")

# ── 10. Eliminar Electro y Baron Zemo ───────────────────────
separador("EJ.2.10 - ELIMINAR ELECTRO Y BARON ZEMO")

a_eliminar = ["Electro", "Baron Zemo"]
for nombre_del in a_eliminar:
    for i, p in enumerate(personajes_marvel):
        if p["nombre"] == nombre_del:
