# --- Función recursiva: buscar Capitan America ---
def buscar_capitan_america(lista, indice=0):
    """Retorna True si 'Capitan America' está en la lista, False si no."""
    if indice == len(lista):
        return False
    if lista[indice] == "Capitan America":
        return True
    return buscar_capitan_america(lista, indice + 1)

# --- Función recursiva: listar superheroes ---
def listar_superheroes(lista, indice=0):
    """Imprime recursivamente todos los superhéroes de la lista."""
    if indice == len(lista):
        return
    print(f"  {indice + 1}. {lista[indice]}")
    listar_superheroes(lista, indice + 1)


